# ── Generator: adr-madr (T9) ───────────────────────────
gen_adr_madr() {
  local title="$1"
  # Auto-number: find highest ADR number and increment
  local adr_dir="docs/development/adr"
  local next_num=1
  if [ -d "$adr_dir" ]; then
    local max_num
    max_num=$(ls "$adr_dir"/adr-*.md 2>/dev/null | grep -oP 'adr-\K\d+' | sort -n | tail -1)
    if [ -n "$max_num" ]; then
      next_num=$((max_num + 1))
    fi
  fi
  local adr_num
  adr_num=$(printf "%03d" $next_num)

  cat <<EOF
---
title: "ADR-$adr_num: $title"
description: "Architecture Decision Record (MADR) — $title"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: proposed
tags: [adr, architecture, decision]
---

# $title

- Status: proposed
- Date: $(today)
- Decision-makers: [$(get_author)]
- Consulted: [names]
- Informed: [names]

## Context and Problem Statement

[Describe the context and problem — 2-3 sentences]

## Decision Drivers

- [Driver 1, e.g., performance requirement]
- [Driver 2, e.g., team expertise]
- [Driver 3, e.g., cost constraint]

## Considered Options

- [Option 1]
- [Option 2]
- [Option 3]

## Decision Outcome

Chosen option: "[Option N]", because [justification].

### Consequences

- Good, because [positive consequence]
- Bad, because [negative consequence]

## Pros and Cons of the Options

### [Option 1]

- Good, because [argument a]
- Good, because [argument b]
- Bad, because [argument c]

### [Option 2]

- Good, because [argument a]
- Bad, because [argument b]

### [Option 3]

- Good, because [argument a]
- Bad, because [argument b]

## More Information

[Links to related ADRs, design docs, meeting notes]
EOF
}

# ── Command: list ────────────────────────────────────────
cmd_list() {
  echo -e "${BLUE}Available document types:${NC}"
  echo ""
  echo "  runbook          System operation runbook (T1)"
  echo "  adr              Architecture Decision Record — Nygard (T2)"
  echo "  howto            Step-by-step how-to guide (T3)"
  echo "  training         Training module (T4)"
  echo "  network          Network topology documentation (T5)"
  echo "  postmortem       Incident postmortem (T6)"
  echo "  maintenance      Maintenance window plan (T7)"
  echo "  release-notes    Version release notes (T8)"
  echo "  adr-madr         ADR — MADR format for complex decisions (T9)"
  echo "  knowledge-check  Training knowledge check (T11)"
  echo "  security-policy  Infrastructure security policy"
  echo "  quick-reference  Quick reference / cheat sheet"
  echo ""
  echo -e "Usage: ${GREEN}$(basename "$0") new <type> <title>${NC}"
}

# ── Command: validate ────────────────────────────────────
cmd_validate() {
  local file="$1"
  if [ -z "$file" ]; then
    echo -e "${RED}Error: specify a file to validate${NC}"
    exit 1
  fi

  if [[ "$file" == *skills/* ]] && [ -f "$TOOLKIT_ROOT/scripts/validate_skill.py" ]; then
    echo -e "${BLUE}Validating skill file...${NC}"
    python3 "$TOOLKIT_ROOT/scripts/validate_skill.py" "$file"
  else
    echo -e "${BLUE}Linting markdown...${NC}"
    if command -v npx &> /dev/null; then
      # Look for project config
      local config_flag=""
      if [ -f ".markdownlint.json" ]; then
        config_flag="--config .markdownlint.json"
      elif [ -f "$TOOLKIT_ROOT/config/.markdownlint.json" ]; then
        config_flag="--config $TOOLKIT_ROOT/config/.markdownlint.json"
      fi
      npx markdownlint-cli2 "$file" $config_flag
    else
      echo -e "${YELLOW}markdownlint-cli2 not found. Run: npm install -g markdownlint-cli2${NC}"
      exit 1
    fi
  fi
}

# ── Command: new ─────────────────────────────────────────
cmd_new() {
  local type="$1"
  local title="$2"

  if [ -z "$type" ] || [ -z "$title" ]; then
    echo -e "${RED}Error: specify type and title${NC}"
    echo "Usage: $(basename "$0") new <type> <title>"
    exit 1
  fi

  local slug
  slug=$(slugify "$title")
  local output_dir=""
  local filename=""
  local content=""

  case "$type" in
    runbook)
      output_dir="docs/operations/runbooks"
      filename="${slug}-runbook.md"
      content=$(gen_runbook "$title")
      ;;
    adr)
      output_dir="docs/development/adr"
      # Auto-number: find highest ADR-NNN and increment
      local last_num=0
      if [ -d "$output_dir" ]; then
        last_num=$(ls "$output_dir"/adr-*.md 2>/dev/null | sed 's/.*adr-0*\([0-9]*\).*/\1/' | sort -n | tail -1 || echo 0)
      fi
      local next_num
      next_num=$(printf "%03d" $((last_num + 1)))
      filename="adr-${next_num}-${slug}.md"
      content=$(gen_adr "$title" "$next_num")
      ;;
    howto)
      output_dir="docs/guides/how-to"
      filename="${slug}-guide.md"
      content=$(gen_howto "$title")
      ;;
    training)
      output_dir="docs/training"
      filename="${slug}-training.md"
      content=$(gen_training "$title")
      ;;
    network)
      output_dir="docs/operations/network"
      filename="${slug}-topology.md"
      content=$(gen_network "$title")
      ;;
    postmortem)
      output_dir="docs/incidents/postmortem"
      filename="$(today)-${slug}.md"
      content=$(gen_postmortem "$title")
      ;;
    maintenance)
      output_dir="docs/operations"
      filename="maintenance-${slug}.md"
      content=$(gen_maintenance "$title")
      ;;
    release-notes)
      output_dir="docs/development"
      filename="release-notes-${slug}.md"
      content=$(gen_release_notes "$title")
      ;;
    adr-madr)
      output_dir="docs/development/adr"
      local last_madr=0
      if [ -d "$output_dir" ]; then
        last_madr=$(ls "$output_dir"/adr-*.md 2>/dev/null | sed 's/.*adr-0*\([0-9]*\).*/\1/' | sort -n | tail -1 || echo 0)
      fi
      local next_madr
      next_madr=$(printf "%03d" $((last_madr + 1)))
      filename="adr-${next_madr}-${slug}.md"
      content=$(gen_adr_madr "$title")
      ;;
    knowledge-check)
      output_dir="docs/training"
      filename="${slug}-knowledge-check.md"
      content=$(gen_knowledge_check "$title")
      ;;
    security-policy)
      output_dir="docs/security"
      filename="${slug}-security-policy.md"
      content=$(gen_security_policy "$title")
      ;;
    quick-reference)
      output_dir="docs/guides/reference"
      filename="${slug}-reference.md"
      content=$(gen_quick_reference "$title")
      ;;
    *)
      echo -e "${RED}Unknown type: ${type}${NC}"
      echo "Run '$(basename "$0") list' to see available types."
      exit 1
      ;;
  esac

  # Create directory and file
  mkdir -p "$output_dir"
  local filepath="${output_dir}/${filename}"

  if [ -f "$filepath" ]; then
    echo -e "${YELLOW}File already exists: ${filepath}${NC}"
    exit 1
  fi

  echo "$content" > "$filepath"
  echo -e "${GREEN}Created: ${filepath}${NC}"

  # Auto-register in mkdocs.yml nav
  local mkdocs_file=""
  if [ -f "mkdocs.yml" ]; then
    mkdocs_file="mkdocs.yml"
  elif [ -f "demo-site/mkdocs.yml" ]; then
    mkdocs_file="demo-site/mkdocs.yml"
  fi

  if [ -n "$mkdocs_file" ]; then
    # Convert filepath to relative path from docs/
    local nav_path="${filepath#docs/}"
    if [ "$mkdocs_file" = "demo-site/mkdocs.yml" ]; then
      nav_path="${filepath#demo-site/docs/}"
    fi
    local nav_entry="      - \"${title}\": ${nav_path}"

    if grep -q "$nav_path" "$mkdocs_file" 2>/dev/null; then
      echo -e "  ${YELLOW}Already in ${mkdocs_file} nav${NC}"
    else
      echo "$nav_entry" >> "$mkdocs_file"
      echo -e "  ${GREEN}Added to ${mkdocs_file} nav${NC}"
      echo -e "  ${YELLOW}Review the nav section to place it in the correct location${NC}"
    fi
  fi

  echo ""
  echo "Next steps:"
  echo "  1. Edit the file and fill in the placeholders"
  echo "     AI Agent: copy prompt from prompts/create-${type}.md"
  echo "  2. Verify: make lint"
  echo "  3. Preview: make serve"
}

# ── Command: adr ─────────────────────────────────────────
cmd_adr() {
  local subcmd="${1:-list}"
  local adr_dir="docs/adr"

  case "$subcmd" in
    list)
      if [ ! -d "$adr_dir" ]; then
        echo -e "${YELLOW}No ADR directory found at $adr_dir${NC}"
        exit 0
      fi

      echo -e "${BLUE}${BOLD}Architecture Decision Records${NC}"
      echo ""
      printf "  %-6s %-50s %-12s %s\n" "#" "Title" "Status" "Date"
      printf "  %-6s %-50s %-12s %s\n" "------" "--------------------------------------------------" "------------" "----------"

      for file in "$adr_dir"/[0-9]*.md; do
        [ -f "$file" ] || continue
        local num title status date
        num=$(basename "$file" | grep -oP '^\d+')
        title=$(grep -m1 "^# " "$file" | sed 's/^# //')
        status=$(grep -oP '\*\*Status\*\*\s*\|\s*\K[^|]+' "$file" | tr -d ' ')
        date=$(grep -oP '\*\*Date\*\*\s*\|\s*\K[^|]+' "$file" | tr -d ' ')
        printf "  %-6s %-50s %-12s %s\n" "$num" "$title" "$status" "$date"
      done
      echo ""
      echo -e "  Total: $(ls "$adr_dir"/[0-9]*.md 2>/dev/null | wc -l) ADR(s)"
      ;;
    *)
      echo -e "${RED}Unknown adr subcommand: $subcmd${NC}"
      echo "Usage: $(basename "$0") adr list"
      exit 1
      ;;
  esac
}

# ── Main ─────────────────────────────────────────────────
case "${1:-}" in
  new)
    cmd_new "$2" "$3"
    ;;
  list)
    cmd_list
    ;;
  adr)
    cmd_adr "$2"
    ;;
  validate)
    cmd_validate "$2"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    usage
    exit 1
    ;;
esac

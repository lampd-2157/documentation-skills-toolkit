#!/bin/bash
# ============================================================
# Documentation Skills Toolkit — CLI Tool
# Author: DulapReal (https://github.com/lampd-2157)
# License: MIT
# Version: 2.0.0
# ============================================================
# Usage:
#   ./scripts/docs-toolkit new <type> <title>
#   ./scripts/docs-toolkit list
#   ./scripts/docs-toolkit validate <file>
# ============================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_ROOT="$(dirname "$SCRIPT_DIR")"

# ── Colors ───────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ── Helpers ──────────────────────────────────────────────
usage() {
  echo "Documentation Skills Toolkit — CLI"
  echo ""
  echo "Usage:"
  echo "  $(basename "$0") new <type> <title>    Create a new document from template"
  echo "  $(basename "$0") list                  List available document types"
  echo "  $(basename "$0") validate <file>       Validate a skill or markdown file"
  echo ""
  echo "Types: runbook, adr, howto, training, network, postmortem, maintenance, release-notes"
  echo ""
  echo "Examples:"
  echo "  $(basename "$0") new runbook \"Nginx Load Balancer\""
  echo "  $(basename "$0") new adr \"Switch to PostgreSQL 16\""
  echo "  $(basename "$0") new postmortem \"DB Connection Pool Exhaustion\""
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//'
}

get_author() {
  git config user.name 2>/dev/null || echo "[Your Name]"
}

today() {
  date +%Y-%m-%d
}

# ── Template Generators ──────────────────────────────────
gen_runbook() {
  local title="$1"
  cat <<EOF
---
title: "Runbook: ${title}"
description: "Operations runbook for ${title}"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: draft
tags: [operations, runbook]
---

# Runbook: ${title}

> Last verified: $(today) | Owner: [Team]

## Overview

| Field           | Value              |
| --------------- | ------------------ |
| **Service**     | ${title}           |
| **Environment** | production         |
| **URL**         | [endpoint URL]     |
| **Repository**  | [git repo link]    |
| **On-call**     | [rotation link]    |

## Architecture

\`\`\`mermaid
graph LR
    A[Client] --> B[${title}]
    B --> C[(Database)]
\`\`\`

## Health Checks

| Check        | Command                | Expected | Alert If    |
| ------------ | ---------------------- | -------- | ----------- |
| Service alive | \`curl -s localhost/hz\` | \`200 OK\` | Non-200     |

## Start / Stop / Restart

| Action  | Command                          | Verify With              |
| ------- | -------------------------------- | ------------------------ |
| Start   | \`sudo systemctl start myapp\`    | \`systemctl status myapp\` |
| Stop    | \`sudo systemctl stop myapp\`     | \`systemctl status myapp\` |
| Restart | \`sudo systemctl restart myapp\`  | \`systemctl status myapp\` |

## Troubleshooting

### [Issue Title]

**Symptoms:** [what you see]
**Root Cause:** [why it happens]
**Fix:**
1. \`[command]\` — [explain]
2. Verify: [expected output]
**Prevention:** [how to prevent]

## Escalation

| Severity | Response | Contact         |
| -------- | -------- | --------------- |
| P1       | 15 min   | [name/rotation] |
| P2       | 1 hour   | [team/Slack]    |
| P3       | 4 hours  | [email/ticket]  |
EOF
}

gen_adr() {
  local title="$1"
  local number="$2"
  cat <<EOF
---
title: "ADR-${number}: ${title}"
description: "Architecture decision record for ${title}"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: proposed
tags: [architecture, adr]
---

# ADR-${number}: ${title}

| Field         | Value     |
| ------------- | --------- |
| **Status**    | Proposed  |
| **Date**      | $(today)  |
| **Author**    | $(get_author) |
| **Reviewers** | [Names]   |

## Context

[What is the issue or opportunity that motivates this decision?]

## Decision

[What is the change that we're proposing?]

## Alternatives Considered

| Option         | Pros       | Cons        |
| -------------- | ---------- | ----------- |
| Option A       | [benefits] | [drawbacks] |
| **Option B** | [benefits] | [drawbacks] |

## Consequences

- **Positive:** [benefits we gain]
- **Negative:** [trade-offs we accept]
- **Risks:** [things to monitor]
EOF
}

gen_howto() {
  local title="$1"
  cat <<EOF
---
title: "How to ${title}"
description: "Step-by-step guide for ${title}"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: draft
tags: [guide, how-to]
---

# How to ${title}

> **Audience:** [role/skill level] | **Time:** ~X min | **Difficulty:** Beginner

## Prerequisites

- [ ] [Tool/access needed 1]
- [ ] [Tool/access needed 2]

## Steps

### Step 1: [Action verb + object]

[Brief explanation]

\`\`\`bash
[copy-paste command]
\`\`\`

**Expected result:**

\`\`\`text
[what you should see]
\`\`\`

### Step 2: [Action verb + object]

[...]

## Verify

- [ ] [How to confirm success]

## Troubleshooting

### Error: [common error message]

**Cause:** [why it happens]
**Fix:** [how to resolve]

## Next Steps

- [Related guide](link)
EOF
}

gen_training() {
  local title="$1"
  cat <<EOF
---
title: "Training: ${title}"
description: "Training module for ${title}"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: draft
tags: [training, onboarding]
---

# Training: ${title}

| Field             | Value                   |
| ----------------- | ----------------------- |
| **Audience**      | [role] — [level]        |
| **Duration**      | [time estimate]         |
| **Prerequisites** | [prior knowledge/tools] |
| **Objectives**    | [what learner achieves] |

## Lesson 1: [Topic]

### Concepts

- **[Concept 1]:** [explanation]
- **[Concept 2]:** [explanation]

### Hands-on Lab

1. [Step] — \`[command/action]\`
   Expected: \`[output]\`
2. [Step] — \`[command/action]\`
   Expected: \`[output]\`

### Knowledge Check

- [ ] Can learner explain [concept]?
- [ ] Did learner complete lab successfully?

## Assessment

| Criteria        | Pass Condition  |
| --------------- | --------------- |
| Lab completion  | 100% steps done |
| Knowledge check | >= 80% correct  |
EOF
}

gen_network() {
  local title="$1"
  cat <<EOF
---
title: "Network Documentation: ${title}"
description: "Network topology and infrastructure for ${title}"
author: "$(get_author)"
created: $(today)
updated: $(today)
status: draft
tags: [network, infrastructure]
---

# Network Documentation: ${title}

## Topology Diagram

\`\`\`mermaid
graph TB
    INET[Internet] --> FW[Firewall]
    FW --> DMZ[DMZ]
    FW --> PROD[Production]
    FW --> MGMT[Management]
\`\`\`

## VLAN Layout

| VLAN ID | Name   | Subnet       | Purpose |
| ------- | ------ | ------------ | ------- |
| [id]    | [name] | [x.x.x.x/xx] | [desc]  |

## Server Inventory

| Hostname   | IP   | OS           | Role   | VLAN |
| ---------- | ---- | ------------ | ------ | ---- |
| [hostname] | [ip] | [os version] | [role] | [id] |

## Firewall Rules

| #   | Source   | Dest   | Port | Action | Note   |
| --- | -------- | ------ | ---- | ------ | ------ |
| 1   | [source] | [dest] | [port] | ALLOW | [note] |

## Certificate Register

| Domain   | Issuer   | Expiry     | Auto-renew |
| -------- | -------- | ---------- | ---------- |
| [domain] | [issuer] | YYYY-MM-DD | Yes/No     |
EOF
}


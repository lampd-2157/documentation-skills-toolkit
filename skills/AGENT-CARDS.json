{
  "version": "5.0.0",
  "description": "Quick-reference skill cards for AI agents. Scan this file instead of reading all 5 skill files (~16K tokens). See config/routing-signals.yaml for smart routing.",
  "template_tiers": {
    "required": "MUST exist in output — reject if missing",
    "recommended": "SHOULD exist — warn if missing",
    "optional": "MAY include when relevant — no penalty if absent"
  },
  "skills": [
    {
      "id": "docs-engineer",
      "file": "skills/docs-engineer.md",
      "iron_law": "Every document MUST pass markdownlint AND render correctly in MkDocs — NO exceptions.",
      "triggers": ["mkdocs", "setup docs", "markdown", "documentation site", "plugins", "site structure"],
      "templates": [],
      "scope_in": ["MkDocs setup", "markdown standards", "site structure", "plugin config", "theme customization"],
      "scope_out": ["runbook content", "training content", "security policy", "ADR content"]
    },
    {
      "id": "ops-runbook-writer",
      "file": "skills/ops-runbook-writer.md",
      "iron_law": "Every runbook MUST have copy-paste commands AND expected output — prose-only = useless.",
      "triggers": ["runbook", "SOP", "ops", "incident", "network", "maintenance", "postmortem", "server", "troubleshooting"],
      "templates": ["T1", "T5", "T6", "T7"],
      "template_sections": {
        "T1": {"required": ["Overview", "Health Checks", "Troubleshooting"], "recommended": ["Architecture", "Start/Stop/Restart", "Escalation"], "optional": ["Backup & Restore", "Monitoring", "Security Notes", "Rollback"]},
        "T5": {"required": ["Topology Diagram", "Server Inventory"], "recommended": ["VLAN Layout", "Firewall Rules"], "optional": ["Certificate Register", "DNS Records", "VPN Config"]},
        "T6": {"required": ["Summary", "Timeline", "Root Cause", "Action Items"], "recommended": ["What Went Wrong", "What Went Right", "Lessons Learned"], "optional": ["SLA Impact", "Blameless Retro", "Cost Impact"]},
        "T7": {"required": ["Pre-checks", "Procedure", "Rollback", "Post-checks"], "recommended": ["Communication Plan"], "optional": ["Risk Assessment", "Monitoring Dashboard"]}
      },
      "scope_in": ["runbook", "ops manual", "network topology", "incident postmortem", "maintenance window"],
      "scope_out": ["training", "ADR", "code documentation", "security policy"]
    },
    {
      "id": "training-doc-writer",
      "file": "skills/training-doc-writer.md",
      "iron_law": "Every training doc MUST have Prerequisites \u2192 Steps \u2192 Expected Result \u2192 Troubleshooting — skip any = incomplete.",
      "triggers": ["training", "onboarding", "curriculum", "learning", "knowledge check", "assessment"],
      "templates": ["T4", "T11"],
      "template_sections": {
        "T4": {"required": ["Lesson", "Assessment"], "recommended": ["Concepts", "Hands-on Lab", "Knowledge Check"], "optional": ["Prerequisites", "Resources", "Instructor Notes"]},
        "T11": {"required": ["Multiple Choice Questions", "Assessment Summary"], "recommended": ["Scenario-based Questions"], "optional": ["Hands-on Verification", "Resources"]}
      },
      "scope_in": ["training module", "onboarding guide", "curriculum", "knowledge check", "learning path"],
      "scope_out": ["runbook", "ADR", "security policy", "release notes"]
    },
    {
      "id": "project-doc-writer",
      "file": "skills/project-doc-writer.md",
      "iron_law": "Every project doc MUST have clear structure with Context \u2192 Decision/Steps \u2192 Consequences/Result — ambiguous docs = wasted decisions.",
      "triggers": ["ADR", "tech spec", "how-to", "guide", "release notes", "decision", "quick reference"],
      "templates": ["T2", "T3", "T8", "T9", "T10"],
      "template_sections": {
        "T2": {"required": ["Context", "Decision", "Consequences"], "recommended": ["Alternatives Considered"], "optional": ["References", "Related ADRs", "Migration Plan"]},
        "T3": {"required": ["Prerequisites", "Steps", "Verify"], "recommended": ["Troubleshooting", "Next Steps"], "optional": ["Rollback", "Security Notes", "FAQ"]},
        "T8": {"required": ["Highlights", "New Features"], "recommended": ["Bug Fixes", "Breaking Changes", "Upgrade Instructions"], "optional": ["Known Issues", "Performance", "Deprecations"]},
        "T9": {"required": ["Context and Problem Statement", "Considered Options", "Decision Outcome"], "recommended": ["Decision Drivers", "Pros and Cons"], "optional": ["Confirmation", "More Information"]},
        "T10": {"required": ["Problem", "Decision"], "recommended": ["Reason", "Impact"], "optional": ["Alternatives", "References"]}
      },
      "scope_in": ["ADR", "tech spec", "how-to guide", "release notes", "quick reference"],
      "scope_out": ["runbook", "training", "security policy", "ops manual"]
    },
    {
      "id": "infra-security-doc",
      "file": "skills/infra-security-doc.md",
      "iron_law": "Every security doc MUST have Scope \u2192 Policy \u2192 Enforcement \u2192 Audit — policy without enforcement = decoration.",
      "triggers": ["security", "RBAC", "access control", "audit", "vulnerability", "compliance", "policy"],
      "templates": [],
      "scope_in": ["security policy", "RBAC matrix", "audit log standards", "vulnerability disclosure"],
      "scope_out": ["runbook", "training", "ADR", "release notes"]
    }
  ]
}

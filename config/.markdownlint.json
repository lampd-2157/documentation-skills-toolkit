{
    "comment": "markdownlint configuration for technical documentation projects",
    "comment2": "Source: DavidAnson/markdownlint — optimized for MkDocs + Material theme",
    "default": true,
    "MD001": true,
    "MD003": {
        "style": "atx"
    },
    "MD004": {
        "style": "dash"
    },
    "MD007": {
        "indent": 2
    },
    "MD009": true,
    "MD010": true,
    "MD012": true,
    "MD013": {
        "line_length": 200,
        "tables": false,
        "code_blocks": false,
        "headings": false
    },
    "MD022": true,
    "MD023": true,
    "MD024": {
        "siblings_only": true
    },
    "MD025": true,
    "MD026": true,
    "MD029": {
        "style": "ordered"
    },
    "MD031": true,
    "MD032": true,
    "MD033": {
        "allowed_elements": [
            "details",
            "summary",
            "br",
            "sup",
            "sub",
            "img",
            "a",
            "kbd",
            "abbr",
            "mark"
        ]
    },
    "MD034": true,
    "MD035": {
        "style": "---"
    },
    "MD036": false,
    "MD040": true,
    "MD041": true,
    "MD046": {
        "style": "fenced"
    },
    "MD048": {
        "style": "backtick"
    },
    "MD056": false,
    "MD058": false,
    "MD060": false
}